#include <stdio.h>
#include <time.h>
#define size 5
int main()
{
    int arr[size];
    int comparisons=0;
    int low=0;
    int high=size-1;
    int found=0;
    int search;
    printf("Enter the elements: \n");
    for(int i=0;i<size;i++)
    {
        scanf("%d",&arr[i]);
    }
    printf("The array: \n");
    for(int i=0;i<size;i++)
    {
        printf("%d ",arr[i]);
    }
    printf("\nWhich number to search ?\n");
    scanf("%d",&search);
    clock_t begin = clock();
    printf("Binary Search: \n");
    while(low<=high)
    {
        comparisons++;
        int mid=(low+high)/2;
        if(arr[mid]==search)
        {
            printf("\nSearch no. found at position %d",mid);
            found=1;
            break;
        }
        else if(arr[mid]<search)
        {
            low=mid+1;
        }
        else
        {
            high=mid-1;
        }
    }
    if(found==0)
    {
        printf("Search no. not found");
    }
    clock_t end = clock();
    double time_elapsed = (double)(end - begin) / CLOCKS_PER_SEC;
    printf("\nTotal execution time: %f seconds\n", time_elapsed);
    printf("No. of comparisons: %d\n\n",comparisons);
    comparisons=0;
    printf("Linear Search: \n");
    found =0;
    clock_t begin2= clock();
    for(int i=0;i<size;i++)
    {
        comparisons++;
        if(arr[i]==search)
        {
            printf("Search no. found at position %d",arr[i]);
            found=1;
            break;
        }
    }
    if(found==0)
    {
        printf("Search no. not found\n");
    }
    clock_t end2 = clock();
    double time_elapsed2= (double)(end2-begin2) / CLOCKS_PER_SEC;
    printf("\nTotal Execution time: %f seconds\n",time_elapsed2);
    printf("No. of comparisons: %d\n",comparisons);
    return 0;
}
